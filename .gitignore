# Obsidian системные файлы (НЕ в git — device-specific!)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
.obsidian/graph-cache.json
# КРИТИЧНО: sync.json содержит userId и токен аутентификации Obsidian Sync.
# Если этот файл в git → git pull каждые 5 мин сбрасывает авторизацию → iPhone не синхронизируется!
.obsidian/sync.json

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Резервные копии
*.backup_*
.trash/

# Временные файлы
*.tmp
*.temp

# Плагины с embedded secrets
.obsidian/plugins/remotely-save/
node_modules/
package-lock.json

# Технические папки (не должны быть в Obsidian/GitHub)
memory/
reports/
package.json
package-lock.json

# Emoji-папки от Obsidian/iPhone — задачи туда не выполняются!
# vault-sync.sh авто-переносит файлы и удаляет эти папки
📝 Задачи/
